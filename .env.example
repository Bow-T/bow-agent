# ─── Claude ───────────────────────────────────────────────────────────────
# CÓ 2 CÁCH AUTH — chỉ cần 1:
#
#   Cách 1 (KHÔNG cần key): đã login Claude CLI sẵn (`claude` → /login) → để TRỐNG
#           dòng dưới. Agent dùng luôn login đó (gói Claude sẵn có, không tốn phí API riêng).
#
#   Cách 2: điền API key (console.anthropic.com → API Keys). Dùng khi chưa login CLI.
ANTHROPIC_API_KEY=

# Model mặc định (không cần đổi trừ khi muốn dùng model khác)
BOW_AGENT_MODEL=claude-opus-4-8

# ─── Jira (tùy chọn — chỉ cần nếu muốn agent tự đọc/ghi ticket) ─────────────
# Base URL của Jira, vd: https://your-company.atlassian.net
JIRA_BASE_URL=
# Email tài khoản Jira
JIRA_EMAIL=
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=
