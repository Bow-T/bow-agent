{
  // Nút "Run and Debug" (Cmd+Shift+D) → chọn 1 cấu hình rồi bấm ▶ (F5).
  "version": "0.2.0",
  "configurations": [
    {
      // MẶC ĐỊNH — bấm ▶ (F5) là chạy cả api + web (chế độ thường). Không cần gõ terminal.
      // Launch thẳng `npm run ui` để VS Code có tiến trình để chạy/dừng; khi bấm Stop
      // thì cả concurrently (api + web) tắt theo. Mở http://localhost:5173 tự động.
      "name": "▶ Chạy Web (api + web)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ui"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "1_run",
        "order": 1
      },
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://localhost:5173)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      // QC Mode — chia sẻ LAN cho QC hỏi đáp read-only + Skill (qc-triage) + Jira.
      // Chạy `ui:qc:share` ở CẶP CỔNG RIÊNG (api :4001, web :5174) nên bật ĐỒNG THỜI với
      // "▶ Chạy Web" (dev :4000/:5173) mà không đụng cổng. Mở http://localhost:5174.
      "name": "🔒 Chạy Web QC Mode (chia sẻ hỏi đáp)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ui:qc:share"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "1_run",
        "order": 2
      },
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://localhost:5174)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      // Collab Mode — cộng tác viên (CTV) qua LAN code gần như dev, nhưng lệnh HỦY HOẠI
      // (rm -rf, deploy, ghi ngoài repo…) phải được ADMIN (localhost) duyệt từ xa; Git tự do.
      // Chạy `ui:collab` ở CẶP CỔNG RIÊNG (api :4002, web :5175) nên bật ĐỒNG THỜI với dev
      // (:4000/:5173) và QC (:4001/:5174). Mở http://localhost:5175.
      "name": "🤝 Chạy Web Collab Mode (CTV code có duyệt)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ui:collab"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "1_run",
        "order": 3
      },
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://localhost:5175)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      // BA Mode — Business Analyst qua LAN: ĐỌC repo, ghi TÀI LIỆU (docs/, *.md) + tạo/sửa
      // Jira ticket; DENY source code / DB / deploy. Chạy `ui:ba` ở CẶP CỔNG RIÊNG (api :4003,
      // web :5176) nên bật ĐỒNG THỜI với dev (:4000/:5173), QC (:4001/:5174) và collab
      // (:4002/:5175). Mở http://localhost:5176.
      "name": "📋 Chạy Web BA Mode (Business Analyst)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ui:ba"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "1_run",
        "order": 4
      },
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://localhost:5176)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      // Reviewer Mode — Tech Lead/Reviewer qua LAN: ĐỌC code, review PR (git/gh diff),
      // comment/approve qua `gh pr`; DENY sửa code / merge / push. Chạy `ui:review:share` ở CẶP
      // CỔNG RIÊNG (api :4004, web :5177) nên bật ĐỒNG THỜI với dev/QC/collab/BA. Mở localhost:5177.
      "name": "🔍 Chạy Web Reviewer Mode (Tech Lead review PR)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ui:review:share"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "1_run",
        "order": 5
      },
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://localhost:5177)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      // DevOps Mode — Triển khai & Hạ tầng qua LAN: ĐỌC repo, ghi FILE HẠ TẦNG (Dockerfile,
      // compose, .github/workflows, *.tf, k8s/Helm) + docs; DENY sửa source ứng dụng; deploy/apply
      // treo admin duyệt. Chạy `ui:devops:share` ở CẶP CỔNG RIÊNG (api :4005, web :5178) nên bật
      // ĐỒNG THỜI với dev/QC/collab/BA/Reviewer. Mở localhost:5178.
      "name": "🛠️ Chạy Web DevOps Mode (Triển khai & Hạ tầng)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ui:devops:share"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "1_run",
        "order": 6
      },
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://localhost:5178)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      // Debug backend Express (src/web/server.ts) qua tsx — ĐẶT BREAKPOINT được ở code .ts.
      // Chạy riêng phần api (:4000). Muốn xem UI thì chạy thêm "web: chạy" hoặc vite riêng.
      "name": "🐛 Debug Backend API (:4000)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/web/server.ts"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "2_debug",
        "order": 1
      }
    },
    {
      // Debug CLI agent (src/cli/index.ts) — chạy agent ở terminal, đặt breakpoint được.
      "name": "🐛 Debug CLI (dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "src/cli/index.ts"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "2_debug",
        "order": 2
      }
    }
  ]
}
