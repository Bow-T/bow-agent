{
  "name": "bow-agent",
  "version": "0.1.0",
  "description": "AI agent nhận đề tài / WBS / Jira ticket rồi tự lập kế hoạch và thực thi (plan-then-approve). Tái sử dụng cho nhiều dự án.",
  "type": "module",
  "bin": {
    "bow-agent": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit",
    "lint:design": "npx @google/design.md lint DESIGN.md",
    "sync-monorepo": "tsx scripts/sync-monorepo.ts",
    "ui": "concurrently -n api,web -c blue,green \"npm run ui:api\" \"npm run ui:web\"",
    "ui:safe": "BOW_SAFE_MODE=true concurrently -n api,web -c blue,green \"npm run ui:api\" \"vite --host\"",
    "ui:stop": "kill -9 $(lsof -t -i:4000 -i:5173) 2>/dev/null || true",
    "ui:restart": "npm run ui:stop && npm run ui:safe",
    "ui:api": "tsx src/web/server.ts",
    "ui:web": "vite",
    "ui:build": "vite build",
    "ui:preview": "npm run ui:build && node --loader tsx src/web/server.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.199",
    "cors": "^2.8.6",
    "dompurify": "^3.4.11",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "iconsax-react": "^0.0.8",
    "marked": "^18.0.5",
    "pdf-parse": "^1.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.25",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.3"
  }
}
